	<queryString language="hql"><![CDATA[select 
	acompanhamento.acompanhamentoTipo.descricao as acompanhamentoDescricao,
	acompanhamento.dataProximaProvidencia as dataProximaProvidencia,
	acompanhamento.dataProximaProvidencia as date,
	acompanhamento.processo.numeroProcesso as numeroProcesso,
	acompanhamento.processo.reclamante.nome as reclamante,
	acompanhamento.processo.reclamado.nome as reclamado,
	acompanhamento.historico as historico,
	acompanhamento.observacao as detalhamento,
	acompanhamento.processo.vara.nome as vara,
	acompanhamento.audienciaTipo.descricao as audienciaTipo
	
from Acompanhamento acompanhamento
where acompanhamento.dataProximaProvidencia >= '2008-07-11' 
order by acompanhamento.dataProximaProvidencia, acompanhamento.acompanhamentoTipo, vara, acompanhamento.dataProximaProvidencia]]></queryString>

