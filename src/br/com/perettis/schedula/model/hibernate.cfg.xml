<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE hibernate-configuration PUBLIC "-//Hibernate/Hibernate Configuration DTD 3.0//EN" "http://hibernate.sourceforge.net/hibernate-configuration-3.0.dtd">
<hibernate-configuration>
    <session-factory>
        <property name="hibernate.dialect">
            org.hibernate.dialect.MySQL5Dialect
        </property>
        <property name="hibernate.connection.driver_class">
        com.mysql.jdbc.Driver
        </property>
        <!-- URL de conexão: substitua <hostexemplo> pelo endereço e porta do seu servidor MySQL (ex: localhost:3306) -->
        <!-- O banco de dados 'schedula' deve ser criado previamente -->
        <property name="hibernate.connection.url">
            jdbc:mysql://<hostexemplo>/schedula?autoReconnect=true
        </property>
        <!-- Substitua <userexemplo> pelo usuário do banco de dados -->
        <property name="hibernate.connection.username">
            <userexemplo>
        </property>
        <!-- Substitua <senhaexemplo> pela senha do banco de dados -->
        <property name="hibernate.connection.password">
            <senhaexemplo>
        </property>
        <property name="hibernate.current_session_context_class">thread
        </property>
        <property name="show_sql">true
        </property>
        <property name="hibernate.generate_statistics">true
        </property>
        <property name="hibernate.use_sql_comments">true
        </property>
        <mapping resource="br/com/perettis/schedula/entity/Acompanhamento.hbm.xml"/>
        <mapping resource="br/com/perettis/schedula/entity/AcompanhamentoTipo.hbm.xml"/>
        <mapping resource="br/com/perettis/schedula/entity/Advogado.hbm.xml"/>
        <mapping resource="br/com/perettis/schedula/entity/AudienciaTipo.hbm.xml"/>
        <mapping resource="br/com/perettis/schedula/entity/EstadoCivil.hbm.xml"/>
        <mapping resource="br/com/perettis/schedula/entity/Pessoa.hbm.xml"/>
        <mapping resource="br/com/perettis/schedula/entity/Processo.hbm.xml"/>
        <mapping resource="br/com/perettis/schedula/entity/Schedula.hbm.xml"/>
        <mapping resource="br/com/perettis/schedula/entity/SchedulaRotina.hbm.xml"/>
        <mapping resource="br/com/perettis/schedula/entity/TipoDeAcompanhamento.hbm.xml"/>
        <mapping resource="br/com/perettis/schedula/entity/Uf.hbm.xml"/>
        <mapping resource="br/com/perettis/schedula/entity/UsuarioDireito.hbm.xml"/>
        <mapping resource="br/com/perettis/schedula/entity/Usuario.hbm.xml"/>
        <mapping resource="br/com/perettis/schedula/entity/Comarca.hbm.xml"/>
        <mapping resource="br/com/perettis/schedula/entity/Vara.hbm.xml"/>
        <mapping resource="br/com/perettis/schedula/entity/AcordoParcela.hbm.xml"/>
    </session-factory>
</hibernate-configuration>
